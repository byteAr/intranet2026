# PostgreSQL
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=pac_db
POSTGRES_USER=pac_user
POSTGRES_PASSWORD=changeme_dev

# JWT — generate with: node -e "require('crypto').randomBytes(64).toString('hex').substr(0,64)" | pbcopy
JWT_SECRET=replace-with-64-char-random-string-change-in-production-now
JWT_EXPIRES_IN=8h

# LDAP — Dev: OpenLDAP local
LDAP_URL=ldap://openldap:389
LDAP_BIND_DN=cn=admin,dc=example,dc=com
LDAP_BIND_CREDENTIALS=admin_password
LDAP_SEARCH_BASE=dc=example,dc=com
LDAP_SEARCH_FILTER=(uid={{username}})
LDAP_TLS_REJECT_UNAUTHORIZED=false

# LDAP — Prod: Active Directory real (descomentar y ajustar)
# LDAP_URL=ldap://ad.empresa.com:389
# LDAP_BIND_DN=CN=svc-account,OU=ServiceAccounts,DC=empresa,DC=com
# LDAP_BIND_CREDENTIALS=service_account_password
# LDAP_SEARCH_BASE=DC=empresa,DC=com
# LDAP_SEARCH_FILTER=(sAMAccountName={{username}})
# LDAP_TLS_REJECT_UNAUTHORIZED=true

# LDAPS — para reset de contraseña directo en AD (requiere puerto 636 abierto)
# LDAPS_URL=ldaps://ad.empresa.com:636

# SMTP (correo para envío de OTP)
SMTP_HOST=smtp.example.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=noreply@example.com
SMTP_PASS=smtp_password
SMTP_FROM=noreply@example.com

# App
FRONTEND_URL=http://localhost:4200
APP_PORT=3000
NODE_ENV=development
